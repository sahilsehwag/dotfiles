#!/usr/bin/env bash
# tmux-relay <verb> [options] [CMD]
#
# Sends tmux commands into the remote tmux session
# running inside the current SSH pane.
# The remote tmux handles splits/windows/popups — they live there.

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$PLUGIN_DIR/lib/context.sh"

PANE_ID=$(tmux display-message -p '#{pane_id}')
VERB="$1"
shift

# Sends: tmux <args>  into the current pane's stdin
remote_tmux() {
	tmux send-keys -t "$PANE_ID" "tmux $*" Enter
}

case "$VERB" in
	split)
		DIR="$1"
		shift
		# -c '#{pane_current_path}' is expanded by the REMOTE tmux, so the
		# new split inherits the remote pane's current directory.
		if [ -n "$*" ]; then
			remote_tmux "split-window $DIR -c '#{pane_current_path}' '$*'"
		else
			remote_tmux "split-window $DIR -c '#{pane_current_path}'"
		fi
		;;
	window)
		if [ -n "$*" ]; then
			remote_tmux "new-window -c '#{pane_current_path}' '$*'"
		else
			remote_tmux "new-window -c '#{pane_current_path}'"
		fi
		;;
	popup)
		remote_tmux "display-popup -E -w 90% -h 90% -x C -y C -d '#{pane_current_path}' '${*:-\$SHELL}'"
		;;
	run)
		remote_tmux "new-window -c '#{pane_current_path}' '$*'"
		;;
	kill)
		# Relay kill-pane to remote tmux
		remote_tmux "kill-pane"
		;;
	kill-other)
		# Relay kill-pane -a (kill all other panes) to remote tmux
		remote_tmux "kill-pane -a"
		;;
	kill-window)
		# Relay kill-window to remote tmux
		remote_tmux "kill-window"
		;;
	kill-session)
		# Relay kill-session to remote tmux
		remote_tmux "kill-session"
		;;
	*)
		# Raw relay: tmux-relay <any tmux command>
		remote_tmux "$VERB $*"
		;;
esac
