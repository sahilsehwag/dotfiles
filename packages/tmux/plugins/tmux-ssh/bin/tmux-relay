#!/usr/bin/env bash
# tmux-relay <verb> [options] [CMD]
#
# Drives the REMOTE tmux server directly over SSH: `ssh <host> tmux <cmd>`.
# This talks to the remote tmux socket — it does NOT fake keystrokes into the
# pane, so it works no matter what is running in the remote pane (vim, less,
# a REPL, or a bare shell). The remote tmux resolves splits/nav/cwd natively.

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$PLUGIN_DIR/lib/context.sh"

VERB="$1"
shift

# Run a tmux command on the REMOTE tmux server via SSH.
# BatchMode + reused ControlMaster keeps this fast. Targets the remote
# server's current client (the session attached in this SSH pane).
remote_tmux() {
	ssh -o BatchMode=yes -o ConnectTimeout=8 "$TSH_HOST" "tmux $*" 2>/dev/null
}

case "$VERB" in
	split)
		DIR="$1"
		shift
		# The remote tmux expands #{pane_current_path} against its own active
		# pane, so the new split inherits the remote pane's directory.
		if [ -n "$*" ]; then
			remote_tmux "split-window $DIR -c '#{pane_current_path}' '$*'"
		else
			remote_tmux "split-window $DIR -c '#{pane_current_path}'"
		fi
		;;
	window)
		if [ -n "$*" ]; then
			remote_tmux "new-window -c '#{pane_current_path}' '$*'"
		else
			remote_tmux "new-window -c '#{pane_current_path}'"
		fi
		;;
	popup)
		remote_tmux "display-popup -E -w 90% -h 90% -x C -y C -d '#{pane_current_path}' '${*:-\$SHELL}'"
		;;
	run)
		remote_tmux "new-window -c '#{pane_current_path}' '$*'"
		;;
	kill)
		remote_tmux "kill-pane"
		;;
	kill-other)
		remote_tmux "kill-pane -a"
		;;
	kill-window)
		remote_tmux "kill-window"
		;;
	kill-session)
		remote_tmux "kill-session"
		;;
	select)
		DIR="$1"
		shift
		remote_tmux "select-pane $DIR"
		;;
	resize)
		DIR="$1"
		shift
		remote_tmux "resize-pane $DIR ${1:-5}"
		;;
	*)
		# Raw relay: tmux-relay <any tmux command>
		remote_tmux "$VERB $*"
		;;
esac
