#!/usr/bin/env bash
# tmux-portal <verb> [options] [CMD]
#
# Each new view = fresh SSH session into the remote host.
# Local tmux is in full control. No nested tmux.
#
# Remote cwd resolution:
#   - If @ssh_dir is set (via ssh-attach), use it.
#   - Otherwise probe the live remote cwd with `ssh <host> pwd` at keypress.
#     Set @ssh_no_probe=1 on the window to skip the probe (opens in $HOME).

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$PLUGIN_DIR/lib/context.sh"

VERB="$1"
shift

# TTL (seconds) for the cached remote cwd. Within this window we use the
# cache instantly and refresh in the background; older than this we probe
# synchronously. Override with @ssh_cwd_ttl.
_TSH_CWD_TTL_DEFAULT=15

# The raw remote probe: read the newest interactive (pts-attached) login
# shell's cwd from /proc, excluding the probe connection's own ancestry.
# Prints the cwd (empty on failure). Uses ControlMaster if configured; the
# connection reuse is what makes this fast.
_tsh_probe_remote_cwd() {
	[ -z "$TSH_HOST" ] && return
	ssh -o BatchMode=yes -o ConnectTimeout=8 "$TSH_HOST" '
		self=$$
		anc=" $self "
		p=$self
		while [ "$p" -gt 1 ]; do
			pp=$(awk "{print \$4}" /proc/$p/stat 2>/dev/null) || break
			[ -z "$pp" ] && break
			anc="$anc $pp "
			p=$pp
		done
		best_start=0; best_cwd=""
		for pid in $(pgrep -u "$(id -u)" -x zsh 2>/dev/null; pgrep -u "$(id -u)" -x bash 2>/dev/null); do
			case "$anc" in *" $pid "*) continue;; esac
			tty=$(readlink /proc/$pid/fd/0 2>/dev/null)
			case "$tty" in *pts*) ;; *) continue;; esac
			cwd=$(readlink /proc/$pid/cwd 2>/dev/null) || continue
			[ -z "$cwd" ] && continue
			st=$(awk "{print \$22}" /proc/$pid/stat 2>/dev/null)
			if [ -n "$st" ] && [ "$st" -gt "$best_start" ]; then best_start=$st; best_cwd=$cwd; fi
		done
		printf "%s" "$best_cwd"
	' 2>/dev/null
}

# Probe and write the result into the window cache (cwd + unix timestamp).
# Meant to be run in the foreground OR backgrounded for a silent refresh.
_tsh_probe_and_cache() {
	local cwd
	cwd=$(_tsh_probe_remote_cwd)
	if [ -n "$cwd" ]; then
		tmux set-window-option "@ssh_cwd_cache" "$cwd" 2>/dev/null
		tmux set-window-option "@ssh_cwd_ts" "$(date +%s)" 2>/dev/null
	fi
	printf '%s' "$cwd"
}

# Resolve the remote working directory.
# Order: explicit @ssh_dir → fresh cache (background-refresh) → sync probe.
_tsh_resolve_dir() {
	# Explicit dir wins.
	if [ -n "$TSH_DIR" ]; then
		printf '%s' "$TSH_DIR"
		return
	fi

	# User opted out of probing entirely.
	local no_probe
	no_probe=$(tmux show-window-options -v @ssh_no_probe 2>/dev/null)
	[ "$no_probe" = "1" ] && return

	[ -z "$TSH_HOST" ] && return

	local ttl cache ts now age
	ttl=$(tmux show-window-options -v @ssh_cwd_ttl 2>/dev/null)
	[ -z "$ttl" ] && ttl=$_TSH_CWD_TTL_DEFAULT
	cache=$(tmux show-window-options -v @ssh_cwd_cache 2>/dev/null)
	ts=$(tmux show-window-options -v @ssh_cwd_ts 2>/dev/null)
	now=$(date +%s)

	if [ -n "$cache" ] && [ -n "$ts" ]; then
		age=$(( now - ts ))
		if [ "$age" -lt "$ttl" ]; then
			# Fresh: use cache instantly, refresh in the background.
			( _tsh_probe_and_cache >/dev/null 2>&1 & ) >/dev/null 2>&1
			printf '%s' "$cache"
			return
		fi
	fi

	# No cache or stale: probe synchronously (fast when ControlMaster is up).
	tmux display-message "tmux-ssh: probing remote cwd on $TSH_HOST…"
	local fresh
	fresh=$(_tsh_probe_and_cache)
	# If the probe failed but we have a stale cache, prefer stale over $HOME.
	if [ -z "$fresh" ] && [ -n "$cache" ]; then
		printf '%s' "$cache"
		return
	fi
	printf '%s' "$fresh"
}

RESOLVED_DIR="$(_tsh_resolve_dir)"

# Escape a value for safe embedding inside a single-quoted string:
#   foo'bar → foo'\''bar
_tsh_sq() { printf "%s" "$1" | sed "s/'/'\\\\''/g"; }

# Build SSH launch string for a pane.
# With CMD: cd dir, run cmd, keep shell after.
# Without: cd dir, shell.
# The whole remote command is single-quoted for `-t`; the cwd is nested-quoted
# with '\'' escaping so paths with spaces or quotes survive.
ssh_launch() {
	local cmd="$1"
	local cd_prefix=""
	if [ -n "$RESOLVED_DIR" ]; then
		cd_prefix="cd '\''$(_tsh_sq "$RESOLVED_DIR")'\'' && "
	fi

	if [ -n "$cmd" ]; then
		echo "ssh $TSH_HOST -t '${cd_prefix}${cmd}; exec \$SHELL'"
	else
		echo "ssh $TSH_HOST -t '${cd_prefix}exec \$SHELL'"
	fi
}

case "$VERB" in
	split)
		DIR="$1"
		shift
		LAUNCH=$(ssh_launch "$*")
		tmux split-window "$DIR" "$LAUNCH"
		;;
	window)
		LAUNCH=$(ssh_launch "$*")
		tmux new-window "$LAUNCH"
		;;
	popup)
		LAUNCH=$(ssh_launch "$*")
		tmux display-popup -E -w 90% -h 90% -x C -y C "$LAUNCH"
		;;
	run)
		# No exec $SHELL — pane closes when done
		cd_prefix=""
		[ -n "$RESOLVED_DIR" ] && cd_prefix="cd '\''$(_tsh_sq "$RESOLVED_DIR")'\'' && "
		LAUNCH="ssh $TSH_HOST -t '${cd_prefix}$*'"
		tmux new-window "$LAUNCH"
		;;
	kill)
		# Local pane op — the SSH session is a local tmux pane.
		tmux kill-pane
		;;
	kill-other)
		tmux kill-pane -a
		;;
	kill-window)
		tmux unlink-window -k
		;;
	kill-session)
		tmux kill-session
		;;
	*)
		echo "tmux-portal: unknown verb '$VERB'" >&2
		exit 1
		;;
esac
